// ReqSploit - Database Schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum CertificateType {
  ROOT_CA
  DOMAIN
}

enum AIMode {
  EDUCATIONAL  // Débutants - Explications détaillées
  DEFAULT      // Standard - Actionnable et rapide
  ADVANCED     // Experts - Analyse technique poussée
}

enum AnalysisType {
  // Analyses de requêtes/réponses
  REQUEST      // Analyse de la requête uniquement
  RESPONSE     // Analyse de la réponse uniquement
  FULL         // Analyse complète (requête + réponse)

  // Rapports et générations AI
  TEST_SUGGESTIONS      // Suggestions de tests pour Repeater
  PAYLOAD_GENERATION    // Payloads de fuzzing générés
  DORK_GENERATION       // Dorks OSINT/reconnaissance
  ATTACK_CHAIN          // Chaînes d'attaque multi-étapes
  SECURITY_REPORT       // Rapports de sécurité complets
}

enum VulnerabilityType {
  SQLi
  XSS_REFLECTED
  XSS_STORED
  XSS_DOM
  IDOR
  SSRF
  XXE
  RCE
  LFI
  RFI
  SSTI
  CSRF
  CORS_MISCONFIGURATION
  JWT_WEAK
  AUTH_BYPASS
  SESSION_FIXATION
  PRIVILEGE_ESCALATION
  INFO_DISCLOSURE
  COMMAND_INJECTION
  LDAP_INJECTION
  XPATH_INJECTION
  PATH_TRAVERSAL
  DESERIALIZATION
  RACE_CONDITION
  BUSINESS_LOGIC
  CUSTOM
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum FindingStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  FALSE_POSITIVE
  WONT_FIX
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

// User Model
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  name          String
  plan          Plan     @default(FREE)
  isActive      Boolean  @default(true)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  sessions                 Session[]
  proxySessions            ProxySession[]
  certificates             Certificate[]
  requestLogs              RequestLog[]
  aiAnalyses               AIAnalysis[]
  aiJobs                   AIJob[]
  tokenUsage               TokenUsage[]
  subscription             Subscription?
  projects                 Project[]
  fuzzingCampaigns         FuzzingCampaign[]
  repeaterTemplates        RepeaterTemplate[]
  dismissedVulnerabilities Vulnerability[]         @relation("DismissedVulnerabilities")
  falsePositivePatterns    FalsePositivePattern[]  @relation("FalsePositivePatterns")
  scanResults              ScanResult[]            @relation("UserScanResults")
  scanPatterns             ScanPattern[]           @relation("UserScanPatterns")
  workSessions             WorkSession[]

  @@index([email])
  @@index([plan])
  @@map("users")
}

// Authentication Session
model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

// Proxy Session
model ProxySession {
  id               String   @id @default(uuid())
  userId           String
  sessionId        String   @unique
  proxyPort        Int?     // Nullable: CDP mode doesn't use ports
  isActive         Boolean  @default(true)
  interceptMode    Boolean  @default(false)
  mode             String   @default("cdp") // "proxy" | "cdp"
  extensionVersion String?  // Chrome extension version
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestLogs RequestLog[]

  @@index([userId])
  @@index([sessionId])
  @@index([isActive])
  @@map("proxy_sessions")
}

// SSL Certificates
model Certificate {
  id        String          @id @default(uuid())
  userId    String
  certPem   String          @db.Text
  keyPem    String          @db.Text // Encrypted
  type      CertificateType
  domain    String?
  expiresAt DateTime
  createdAt DateTime        @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([domain])
  @@map("certificates")
}

// HTTP Request Logs
model RequestLog {
  id               String    @id @default(uuid())
  userId           String
  proxySessionId   String
  projectId        String?
  method           String
  url              String    @db.Text
  headers          Json
  body             String?   @db.Text
  statusCode       Int?
  responseHeaders  Json?
  responseBody     String?   @db.Text
  duration         Int? // milliseconds
  timestamp        DateTime  @default(now())
  isIntercepted    Boolean   @default(false)
  tags             String[]  @default([])
  starred          Boolean   @default(false)
  tabId            Int?      // Browser tab ID (CDP mode)
  resourceType     String?   // "Document", "XHR", "Fetch", etc. (CDP mode)

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  proxySession ProxySession  @relation(fields: [proxySessionId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  aiAnalyses   AIAnalysis[]
  scanResults  ScanResult[]

  @@index([userId])
  @@index([proxySessionId])
  @@index([projectId])
  @@index([timestamp])
  @@index([isIntercepted])
  @@index([starred])
  @@map("request_logs")
}

// AI Analysis Results
model AIAnalysis {
  id               String             @id @default(uuid())
  requestLogId     String?            // Nullable: reports/attack chains not tied to single request
  projectId        String?            // For security reports and attack chains
  workSessionId    String?            // Link to work session
  analysisType     AnalysisType       // Extended types: REQUEST, RESPONSE, FULL, TEST_SUGGESTIONS, etc.
  mode             AIMode             @default(DEFAULT)

  // Metadata
  title            String?            // "Security Report" / "XSS Test Suite" / etc.
  category         String?            // "sqli" / "xss" / "recon" / "auth" / etc.
  userContext      String?            @db.Text

  // AI Response
  aiResponse       String             @db.Text
  suggestions      Json
  tokensUsed       Int
  confidence       Int                @default(0) // 0-100
  model            String?            // Model used (haiku-4.5 or sonnet-4.5)
  createdAt        DateTime           @default(now())
  userId           String

  // Relations
  requestLog      RequestLog?        @relation(fields: [requestLogId], references: [id], onDelete: Cascade)
  project         Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workSession     WorkSession?       @relation(fields: [workSessionId], references: [id], onDelete: SetNull)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  vulnerabilities Vulnerability[]
  jobs            AIJob[]            // Jobs that resulted in this analysis

  @@index([requestLogId])
  @@index([projectId])
  @@index([workSessionId])
  @@index([userId])
  @@index([analysisType])
  @@index([mode])
  @@index([createdAt])
  @@map("ai_analyses")
}

// Vulnerability Details
model Vulnerability {
  id            String            @id @default(uuid())
  analysisId    String
  type          VulnerabilityType
  severity      Severity
  title         String
  description   String            @db.Text
  evidence      Json
  remediation   String            @db.Text
  cwe           String?
  cvss          Float?
  createdAt     DateTime          @default(now())

  // False Positive Management (Module 3.1)
  status        FindingStatus     @default(OPEN)
  dismissedAt   DateTime?
  dismissedBy   String?
  dismissReason String?           @db.Text
  confidence    Int               @default(50) // 0-100: AI confidence in this finding

  // Relations
  analysis      AIAnalysis        @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  dismissedUser User?             @relation("DismissedVulnerabilities", fields: [dismissedBy], references: [id], onDelete: SetNull)

  @@index([analysisId])
  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([dismissedBy])
  @@map("vulnerabilities")
}

// False Positive Patterns (Module 3.1)
// Stores patterns learned from dismissed vulnerabilities for auto-suppression
model FalsePositivePattern {
  id              String            @id @default(uuid())
  userId          String
  vulnerabilityType VulnerabilityType
  pattern         Json              // Pattern matching rules (URL, headers, body patterns)
  confidence      Int               @default(50) // 0-100: Pattern accuracy
  matchCount      Int               @default(0) // Number of times this pattern matched
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  isActive        Boolean           @default(true)

  // Relations
  user User @relation("FalsePositivePatterns", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([vulnerabilityType])
  @@index([isActive])
  @@map("false_positive_patterns")
}

// Project/Target Organization
model Project {
  id          String      @id @default(uuid())
  userId      String
  name        String
  description String?     @db.Text
  target      String // Base URL
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests     RequestLog[]
  findings     Finding[]
  aiAnalyses   AIAnalysis[] // Security reports and attack chains
  workSessions WorkSession[]

  @@index([userId])
  @@index([target])
  @@map("projects")
}

// Findings/Discoveries
model Finding {
  id          String        @id @default(uuid())
  projectId   String
  title       String
  description String        @db.Text
  severity    Severity
  status      FindingStatus @default(OPEN)
  proof       Json // Screenshots, requests, etc.
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([severity])
  @@index([status])
  @@map("findings")
}

// Token Usage Tracking
model TokenUsage {
  id          String   @id @default(uuid())
  userId      String
  monthYear   String // Format: YYYY-MM
  tokensUsed  Int      @default(0)
  tokensLimit Int
  resetDate   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthYear])
  @@index([userId])
  @@index([monthYear])
  @@map("token_usage")
}

// Subscription Management
model Subscription {
  id                    String             @id @default(uuid())
  userId                String             @unique
  plan                  Plan
  stripeCustomerId      String?            @unique
  stripeSubscriptionId  String?            @unique
  status                SubscriptionStatus @default(ACTIVE)
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

// Fuzzing Campaigns (Intruder)
model FuzzingCampaign {
  id                String   @id @default(uuid())
  userId            String
  name              String
  requestTemplate   Json // Original request with §markers§
  payloadPositions  Json // Marker positions and types
  payloadSets       Json // Payload assignments
  attackType        String // sniper|battering_ram|pitchfork|cluster_bomb
  concurrency       Int      @default(5)
  delayMs           Int      @default(0)
  status            String   @default("pending") // pending|running|paused|completed|stopped
  totalRequests     Int      @default(0)
  completedRequests Int      @default(0)
  failedRequests    Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  startedAt         DateTime?
  completedAt       DateTime?

  // Relations
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  results FuzzingResult[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("fuzzing_campaigns")
}

// Fuzzing Results
model FuzzingResult {
  id             String   @id @default(uuid())
  campaignId     String
  payloadSet     Json // Actual payloads used
  request        Json // Full request sent
  statusCode     Int?
  responseLength Int?
  responseTime   Int? // milliseconds
  response       Json? // Headers + body
  error          String?
  timestamp      DateTime @default(now())

  // Relations
  campaign FuzzingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([statusCode])
  @@index([responseLength])
  @@index([responseTime])
  @@index([timestamp])
  @@map("fuzzing_results")
}

// Repeater Templates (Phase 5)
model RepeaterTemplate {
  id        String   @id @default(uuid())
  userId    String
  name      String
  method    String
  url       String   @db.Text
  headers   Json
  body      String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("repeater_templates")
}

// ============================================
// MAGIC SCAN - Sensitive Data Discovery
// ============================================

enum AssetCategory {
  API_KEYS
  PRIVATE_KEYS
  DATABASE_CREDS
  AUTH_DATA
  NETWORK_INFO
  PII
  SENSITIVE_FILES
  ERROR_INFO
  BUSINESS_LOGIC
}

model ScanResult {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation("UserScanResults", fields: [userId], references: [id], onDelete: Cascade)

  // Request reference
  requestId String?
  request   RequestLog? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  // Finding details
  severity     Severity
  category     AssetCategory
  type         String       // AWS_ACCESS_KEY, JWT_TOKEN, etc.
  description  String

  // Value storage
  value         String       // Masked value for display
  valueHash     String       // SHA256 hash for deduplication
  fullValue     String?      // Encrypted full value (optional)

  // Location information
  location      Json         // {source: 'request'|'response', part: 'headers'|'body'|'url', path: string}
  context       String       @db.Text // Surrounding text (50 chars before/after)

  // Metadata
  confidence    Int          // 0-100 confidence score
  isMarkedSafe  Boolean      @default(false)
  isFalsePositive Boolean    @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, severity])
  @@index([userId, category])
  @@index([userId, isMarkedSafe])
  @@index([valueHash]) // For deduplication
  @@index([requestId])
  @@index([createdAt])
  @@map("scan_results")
}

model ScanPattern {
  id          String   @id @default(uuid())
  userId      String?  // Null = global pattern, User ID = user-specific override
  user        User?    @relation("UserScanPatterns", fields: [userId], references: [id], onDelete: Cascade)

  category    AssetCategory
  type        String
  severity    Severity
  pattern     String   @db.Text // Regex pattern as string
  description String
  enabled     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, enabled])
  @@index([category])
  @@map("scan_patterns")
}

// ============================================
// AI JOB QUEUE - Persistent background AI jobs
// ============================================

enum AIJobStatus {
  PENDING      // Waiting to be processed
  PROCESSING   // Currently being processed
  COMPLETED    // Successfully completed
  FAILED       // Failed with error
  CANCELLED    // Cancelled by user
}

enum AIJobType {
  SUGGEST_TESTS      // Test suggestions for Repeater
  GENERATE_PAYLOADS  // Payload generation for fuzzing
  GENERATE_DORKS     // OSINT/recon dork generation
  ATTACK_CHAIN       // Multi-step attack chain
  SECURITY_REPORT    // Security report generation
  ANALYZE_REQUEST    // Request analysis
  ANALYZE_RESPONSE   // Response analysis
}

// AI Job Queue - Persistent background AI processing
model AIJob {
  id          String      @id @default(uuid())
  userId      String
  type        AIJobType
  status      AIJobStatus @default(PENDING)

  // Job data
  requestData Json        // Original request to process (method, url, headers, body, etc.)
  model       String?     // Preferred model (haiku-4.5, sonnet-4.5, auto)
  mode        AIMode      @default(DEFAULT)

  // Result reference
  resultId    String?     // Links to AIAnalysis when completed
  errorMessage String?    @db.Text // Error details if failed

  // Progress tracking
  progress    Int         @default(0) // 0-100 percentage

  // Timestamps
  createdAt   DateTime    @default(now())
  startedAt   DateTime?   // When processing started
  completedAt DateTime?   // When processing finished

  // Retry logic
  attempts    Int         @default(0)
  maxAttempts Int         @default(3)
  lastError   String?     @db.Text

  // Relations
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  result      AIAnalysis? @relation(fields: [resultId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([type])
  @@index([resultId])
  @@map("ai_jobs")
}

// ============================================
// WORK SESSIONS - Session-based organization
// ============================================

// Work Sessions for organizing testing activities and AI analyses
model WorkSession {
  id           String   @id @default(uuid())
  userId       String
  projectId    String?  // Optional project association

  // Session info
  name         String   // "API Payment Testing" / "Recon Phase 1" / etc.
  description  String?  @db.Text

  // Session lifecycle
  startedAt    DateTime @default(now())
  endedAt      DateTime?
  isActive     Boolean  @default(true)

  // Statistics
  totalRequests   Int @default(0)
  totalAnalyses   Int @default(0)
  tokensConsumed  Int @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  aiAnalyses  AIAnalysis[]  // All AI reports from this session

  @@index([userId, isActive])
  @@index([projectId])
  @@index([startedAt])
  @@map("work_sessions")
}
